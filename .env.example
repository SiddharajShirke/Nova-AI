# ============================================================
#  Nova AI — Environment Variables
#  Copy this file to .env and fill in your actual keys
# ============================================================

# --- NVIDIA NIM (Primary LLM) ---
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# --- Google Gemini (Fallback LLM) ---
GOOGLE_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GEMINI_MODEL=gemini-1.5-flash-latest

# --- Google PageSpeed Insights (optional, uses heuristics if absent) ---
PAGESPEED_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./nova_ai.db

# --- App ---
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-64-char-string
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- PDF Reports ---
REPORTS_DIR=./reports
